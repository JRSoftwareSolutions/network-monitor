{
  "private": true,
  "browserslist": [
    "Chrome >= 111",
    "Firefox >= 113",
    "Edge >= 111"
  ],
  "scripts": {
    "build:css": "sass static/scss/main.scss static/css/main.interim.css --no-source-map --load-path=static/css && postcss static/css/main.interim.css -o static/css/app.css",
    "watch:css:sass": "sass static/scss/main.scss static/css/main.interim.css --watch --no-source-map --load-path=static/css",
    "watch:css:postcss": "postcss static/css/main.interim.css -o static/css/app.css --watch",
    "watch:css": "npm run build:css && concurrently -k -n sass,postcss -c yellow,cyan \"npm:watch:css:sass\" \"npm:watch:css:postcss\"",
    "vendor:gridstack": "node scripts/vendor-gridstack.mjs",
    "lint:css": "stylelint \"static/scss/**/*.scss\" --ignore-path .gitignore",
    "test:py": "python -m pytest tests/py -q",
    "test:unit": "node --test tests/js/*.test.mjs",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:py && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.49.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^10.1.6",
    "concurrently": "^9.1.2",
    "gridstack": "11.3.0",
    "sass": "^1.77.6",
    "stylelint": "^16.19.1",
    "stylelint-config-standard-scss": "^14.0.0"
  }
}
